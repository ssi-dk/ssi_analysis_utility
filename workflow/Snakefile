import pandas as pd
import yaml
import warnings
from scripts import rule_all_functions 

configfile: "config/config.yaml"

# --- Inputs & paths from config file------------------------------------------------
samplesheet_path = config['input_manager']['samplesheet']
output_folder    = config['input_manager']['output_folder']
metadata_path    = config['input_manager']['metadata_path']   # used by finder rules
database_path    = config['input_manager']['database_path']   # used by setup rules
species_config_path = config['input_manager']['config_species'] # Path to species specific configuration files
temp_storage_path = config['input_manager']['temp_storage']
species_name_map =  config['species_map'] # Load species_name_map from config file

samplesheet = pd.read_csv(samplesheet_path, sep='\t')

# --- Samples & read locations -------------------------------------------------
sample_to_illumina, sample_to_nanopore, sample_to_assembly_file = rule_all_functions.sample_read_map(samplesheet)

# ------------------ Species Mapping (from config) ------------------

# Map each sample species (from sample sheet information) to the normalized species name used for the Species specific config
sample_to_organism,unmapped_species = rule_all_functions.sample_map(species_name_map,samplesheet) 

if unmapped_species: #check if species have not properly been mapped
    warnings.warn("The following species are not mapped in config['species_map']: %s" % unmapped_species, UserWarning)

# ------------------ Load Species-Specific Configs ------------------

species_configs = rule_all_functions.sample_to_species_config(sample_to_organism,species_config_path)

##############################################################################
#
#                              Snakefile 
#
##############################################################################

# Define the dynamic input for rule all
rule all:
    input:
        rule_all_functions.list_results(
            samplesheet=samplesheet,
            species_configs=species_configs,
            output_folder=output_folder,
            species_name_map=species_name_map,
        )

print(rule_all_functions.list_results(
            samplesheet=samplesheet,
            species_configs=species_configs,
            output_folder=output_folder,
            species_name_map=species_name_map,
        ))

include : "rules/assemblers.smk"
include : "rules/fetch_custom_dbs.smk"
include : "rules/setup_dbs.smk"
include : "rules/mappers.smk"
include : "rules/htslib_utils.smk"
include : "rules/finders.smk"
include : "rules/characterizers.smk"
include : "rules/custom_wranglers.smk"
